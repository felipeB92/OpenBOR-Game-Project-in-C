# Do not forget to name your character.
# Health is optional.

name	Cabine
health	1
type	obstacle
gfxshadow	1
#icon	data/chars/misc/charicon.gif
diesound data/sounds/glass.wav
noatflash	1

anim idle
	loop	0
	delay	100
	offset	33 112
